---
import ShapeBlur from './reactbits/ShapeBlur';
---
<section class="profile-section">
  <div class="profile-card">
    <div class="avatar-wrapper">
      <div class="blur-container">
        <ShapeBlur
          client:only="react"
          variation={0}
          shapeSize={1}
          roundness={1}
          borderSize={0.03}
          circleSize={0.25}
          circleEdge={1}
        />
      </div>
      <div class="avatar-ring">
        <img src="/Avatar.jpg" alt="Author Avatar" />
      </div>
    </div>
    <div class="bio">
      <p class="greeting">HI, I'M JAY</p>
      <p class="description">Building digital products, exploring Web3, and crafting immersive web experiences.</p>
    </div>
  </div>
</section>

<style>
.profile-section {
  pointer-events: none;
}

.profile-card {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  background: rgba(255, 255, 255, 0.08); 
  backdrop-filter: blur(20px);
  padding: 1.25rem 2.5rem 1.25rem 1.25rem;
  border-radius: 100px;
  border: 1px solid rgba(255, 255, 255, 0.25);
  width: fit-content;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);
}

.avatar-wrapper {
  position: relative;
  width: 98px; /* Made bigger per request */
  height: 98px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.avatar-ring {
  width: 92px; /* Matching size */
  height: 92px;
  border-radius: 50%;
  padding: 3px;
  background: rgba(255, 255, 255, 0.1);
  box-shadow: 0 4px 20px rgba(0,0,0,0.3);
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  z-index: 1; /* Reset base level */
}

.blur-container {
  position: absolute;
  inset: -50px; 
  z-index: 5; /* Pushed HIGHER than the avatar image to sit on top */
  pointer-events: none;
  border-radius: 50%;
  overflow: hidden; 
}

.avatar-ring img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
  background: #000; 
  position: relative;
  z-index: 2; /* Below the blur-container */
  border: 1px solid rgba(255, 255, 255, 0.15);
}

.bio .greeting {
  font-family: 'Space Grotesk', 'Inter', sans-serif;
  font-weight: 700;
  font-size: 1.2rem;
  margin: 0 0 0.5rem 0;
  color: #fff;
  letter-spacing: 0.05em;
}

.bio .description {
  font-family: 'Inter', sans-serif;
  font-size: 0.95rem;
  color: rgba(255,255,255,0.7);
  margin: 0;
  max-width: 320px;
  line-height: 1.5;
}

@media (max-width: 820px) {
  .profile-section {
    margin-top: 15vh;
    margin-left: 0;
    display: flex;
    justify-content: center;
    padding: 0 20px;
  }
  .profile-card {
    flex-direction: column;
    text-align: center;
    border-radius: 24px;
    padding: 2rem;
  }
  .bio .description {
    max-width: 100%;
  }
}
</style>
