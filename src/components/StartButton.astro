---
const href = Astro.props.href ?? '/blog';
const label = Astro.props.label ?? 'ENTER';
---

<div class="start-button-wrap">
    <a href={href} class="start-button" aria-label={`${label} the blog`}>
        <span class="start-button__label">{label}</span>
        <svg
            class="start-button__arrow"
            viewBox="0 0 24 24"
            width="16"
            height="16"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
        >
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
        </svg>
    </a>
</div>

<style>
    .start-button-wrap {
        position: fixed;
        /* PC default: aligned with the JAY'S BLOG wordmark's left edge */
        left: clamp(72px, 10vw, 132px);
        bottom: calc(env(safe-area-inset-bottom, 0) + clamp(20px, 4vh, 36px));
        z-index: 50;
        transform: translate(var(--mag-x, 0), var(--mag-y, 0));
        transition: transform 600ms cubic-bezier(0.2, 0.8, 0.2, 1);
        will-change: transform;
        pointer-events: auto;
    }

    .start-button {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 14px 26px;

        font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
        font-size: 0.9rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        color: #1a1a1a;
        text-decoration: none;
        white-space: nowrap;

        border-radius: 999px;
        background: rgba(255, 255, 255, 0.5);
        -webkit-backdrop-filter: blur(14px) saturate(1.6);
        backdrop-filter: blur(14px) saturate(1.6);
        border: 1px solid rgba(255, 255, 255, 0.55);
        box-shadow:
            0 6px 22px rgba(17, 17, 26, 0.08),
            0 2px 8px rgba(17, 17, 26, 0.05),
            inset 0 1px 0 rgba(255, 255, 255, 0.55);

        overflow: hidden;
        isolation: isolate;
        cursor: pointer;
        transition:
            transform 400ms cubic-bezier(0.2, 0.8, 0.2, 1),
            background 300ms ease,
            box-shadow 400ms ease;

        /* Entrance after Spline settles */
        animation: start-in 900ms cubic-bezier(0.2, 0.8, 0.2, 1) 600ms both;
    }

    @keyframes start-in {
        from {
            opacity: 0;
            transform: translateY(14px) scale(0.96);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    /* Conic sweep ring (hover) */
    .start-button::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: inherit;
        padding: 1.5px;
        background: conic-gradient(
            from 0deg,
            transparent 0deg,
            rgba(255, 200, 60, 0.8) 60deg,
            rgba(255, 120, 200, 0.55) 140deg,
            rgba(120, 180, 255, 0.55) 220deg,
            transparent 320deg
        );
        -webkit-mask:
            linear-gradient(#000 0 0) content-box,
            linear-gradient(#000 0 0);
        mask:
            linear-gradient(#000 0 0) content-box,
            linear-gradient(#000 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        opacity: 0;
        transition: opacity 400ms ease;
        pointer-events: none;
        z-index: 2;
    }

    /* Ambient glow behind the capsule (hover) */
    .start-button::after {
        content: '';
        position: absolute;
        inset: -20px;
        background: radial-gradient(
            circle at 50% 60%,
            rgba(255, 195, 70, 0.35) 0%,
            rgba(255, 195, 70, 0) 60%
        );
        opacity: 0;
        filter: blur(14px);
        pointer-events: none;
        z-index: -1;
        transition: opacity 500ms ease;
    }

    .start-button:hover {
        transform: translateY(-2px);
        background: rgba(255, 255, 255, 0.62);
        box-shadow:
            0 12px 32px rgba(17, 17, 26, 0.1),
            0 4px 14px rgba(17, 17, 26, 0.06),
            inset 0 1px 0 rgba(255, 255, 255, 0.7);
    }

    .start-button:hover::before {
        opacity: 1;
        animation: sweep 3.6s linear infinite;
    }

    .start-button:hover::after {
        opacity: 1;
    }

    @keyframes sweep {
        to {
            transform: rotate(360deg);
        }
    }

    .start-button:active {
        transform: translateY(0) scale(0.97);
        transition-duration: 100ms;
    }

    .start-button__label,
    .start-button__arrow {
        position: relative;
        z-index: 3;
        transition: transform 400ms cubic-bezier(0.2, 0.8, 0.2, 1);
    }

    .start-button:hover .start-button__label {
        transform: translateX(-2px);
    }

    .start-button:hover .start-button__arrow {
        transform: translateX(4px);
    }

    .start-button:focus-visible {
        outline: 2px solid rgba(255, 195, 70, 0.9);
        outline-offset: 3px;
    }

    /* Mobile: sit above SocialsDock capsule */
    @media (max-width: 820px) {
        .start-button-wrap {
            left: clamp(14px, 4vw, 24px);
            bottom: calc(env(safe-area-inset-bottom, 0) + 64px);
        }

        .start-button {
            padding: 10px 20px;
            font-size: 0.78rem;
            letter-spacing: 0.12em;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .start-button-wrap,
        .start-button,
        .start-button::before,
        .start-button::after,
        .start-button__label,
        .start-button__arrow {
            animation: none !important;
            transition: none !important;
        }
    }
</style>

<script>
    const wrap = document.querySelector<HTMLElement>('.start-button-wrap');
    const canHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

    if (wrap && canHover) {
        const RANGE = 140;
        const STRENGTH = 0.35;
        let rafId = 0;
        let lastX = 0;
        let lastY = 0;
        let pending = false;

        const tick = () => {
            rafId = 0;
            if (!pending) return;
            pending = false;

            const rect = wrap.getBoundingClientRect();
            const cx = rect.left + rect.width / 2;
            const cy = rect.top + rect.height / 2;
            const dx = lastX - cx;
            const dy = lastY - cy;
            const dist = Math.hypot(dx, dy);

            if (dist < RANGE) {
                const pull = (1 - dist / RANGE) * STRENGTH;
                wrap.style.setProperty('--mag-x', `${dx * pull}px`);
                wrap.style.setProperty('--mag-y', `${dy * pull}px`);
            } else {
                wrap.style.setProperty('--mag-x', '0px');
                wrap.style.setProperty('--mag-y', '0px');
            }
        };

        document.addEventListener('mousemove', (e: MouseEvent) => {
            lastX = e.clientX;
            lastY = e.clientY;
            pending = true;
            if (!rafId) rafId = requestAnimationFrame(tick);
        });
    }
</script>
