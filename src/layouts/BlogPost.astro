---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import FormattedDate from '../components/FormattedDate.astro';
import GlassTopBar from '../components/GlassTopBar';
import SocialsDock from '../components/SocialsDock.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body class="blog-post-page">
		<GlassTopBar client:only="react" />
		<SocialsDock />

		<article class="blog-post">
			{heroImage && (
				<div class="blog-post__hero">
					<Image width={1500} height={600} src={heroImage} alt="" loading="eager" />
				</div>
			)}

			<div class="blog-post__container">
				<header class="blog-post__head">
					<a href="/blog" class="blog-post__back">
						<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<polyline points="15 18 9 12 15 6" />
						</svg>
						<span>ALL WRITINGS</span>
					</a>

					<p class="blog-post__eyebrow">
						<FormattedDate date={pubDate} />
						{updatedDate && (
							<span class="blog-post__updated">
								{' · Updated '}
								<FormattedDate date={updatedDate} />
							</span>
						)}
					</p>

					<h1 class="blog-post__title">{title}</h1>
					{description && <p class="blog-post__desc">{description}</p>}
				</header>

				<hr class="blog-post__divider" />

				<div class="blog-post__prose">
					<slot />
				</div>
			</div>
		</article>
	</body>
</html>

<style is:global>
	body.blog-post-page {
		margin: 0;
		min-height: 100vh;
		background: #DCDCDC;
		color: #1a1a1a;
		font-family: 'Atkinson', system-ui, -apple-system, 'Segoe UI', sans-serif;
	}

	body.blog-post-page *,
	body.blog-post-page *::before,
	body.blog-post-page *::after {
		box-sizing: border-box;
	}

	/* =====================
	   Prose (Markdown output)
	   ===================== */
	.blog-post__prose {
		font-size: 1.08rem;
		line-height: 1.78;
		color: #2a2a2a;
	}

	.blog-post__prose p {
		margin: 0 0 1.2em;
	}

	.blog-post__prose h1,
	.blog-post__prose h2,
	.blog-post__prose h3,
	.blog-post__prose h4 {
		color: #1a1a1a;
		font-weight: 700;
		line-height: 1.25;
		margin: 2.2em 0 0.6em;
		letter-spacing: -0.01em;
	}

	.blog-post__prose h1 { font-size: 1.9rem; }
	.blog-post__prose h2 { font-size: 1.55rem; }
	.blog-post__prose h3 { font-size: 1.22rem; }
	.blog-post__prose h4 { font-size: 1.08rem; }

	.blog-post__prose a {
		color: #b05a00;
		text-decoration: underline;
		text-decoration-color: rgba(255, 180, 60, 0.55);
		text-underline-offset: 3px;
		transition: color 200ms ease, text-decoration-color 200ms ease;
	}

	.blog-post__prose a:hover {
		color: #804000;
		text-decoration-color: rgba(255, 150, 40, 1);
	}

	.blog-post__prose img {
		display: block;
		max-width: 100%;
		height: auto;
		margin: 1.8em auto;
		border-radius: 14px;
		box-shadow: 0 6px 28px rgba(17, 17, 26, 0.1);
	}

	.blog-post__prose blockquote {
		margin: 1.6em 0;
		padding: 14px 22px;
		background: rgba(255, 195, 70, 0.1);
		border-left: 3px solid rgba(255, 170, 40, 0.7);
		border-radius: 0 12px 12px 0;
		color: #4a3a20;
		font-style: italic;
	}

	.blog-post__prose blockquote p {
		margin: 0;
	}

	.blog-post__prose code {
		font-family: 'JetBrains Mono', 'SF Mono', Menlo, Consolas, monospace;
		font-size: 0.92em;
		padding: 2px 6px;
		border-radius: 6px;
		background: rgba(26, 26, 26, 0.06);
		color: #3a3a3a;
	}

	.blog-post__prose pre {
		margin: 1.6em 0;
		padding: 18px 20px;
		border-radius: 14px;
		background: rgba(26, 26, 26, 0.92);
		color: #f4f4f4;
		overflow-x: auto;
		font-size: 0.92rem;
		line-height: 1.6;
		box-shadow:
			0 6px 22px rgba(17, 17, 26, 0.12),
			inset 0 1px 0 rgba(255, 255, 255, 0.08);
	}

	.blog-post__prose pre code {
		background: none;
		padding: 0;
		color: inherit;
		font-size: inherit;
	}

	.blog-post__prose ul,
	.blog-post__prose ol {
		margin: 0 0 1.2em;
		padding-left: 1.5em;
	}

	.blog-post__prose li {
		margin-bottom: 0.3em;
	}

	.blog-post__prose hr {
		border: none;
		height: 1px;
		margin: 2.5em 0;
		background: linear-gradient(to right, transparent, rgba(17, 17, 26, 0.15), transparent);
	}

	.blog-post__prose table {
		width: 100%;
		border-collapse: collapse;
		margin: 1.6em 0;
	}

	.blog-post__prose th,
	.blog-post__prose td {
		padding: 10px 14px;
		border-bottom: 1px solid rgba(17, 17, 26, 0.08);
		text-align: left;
	}

	.blog-post__prose th {
		font-weight: 700;
		color: #1a1a1a;
	}

	@media (max-width: 820px) {
		.blog-post__prose {
			font-size: 1rem;
			line-height: 1.7;
		}
		.blog-post__prose h1 { font-size: 1.5rem; }
		.blog-post__prose h2 { font-size: 1.32rem; }
		.blog-post__prose h3 { font-size: 1.15rem; }
		.blog-post__prose pre {
			padding: 14px 16px;
			font-size: 0.85rem;
			border-radius: 12px;
		}
		.blog-post__prose blockquote {
			padding: 12px 18px;
		}
	}
</style>

<style>
	.blog-post {
		padding: clamp(90px, 14vh, 140px) 0 180px;
	}

	.blog-post__hero {
		max-width: 1200px;
		margin: 0 auto 60px;
		padding: 0 clamp(16px, 4vw, 48px);
	}

	.blog-post__hero img {
		width: 100%;
		aspect-ratio: 5 / 2;
		height: auto;
		object-fit: cover;
		display: block;
		border-radius: 24px;
		box-shadow:
			0 10px 40px rgba(17, 17, 26, 0.1),
			0 3px 14px rgba(17, 17, 26, 0.06);
	}

	.blog-post__container {
		max-width: 720px;
		margin: 0 auto;
		padding: 0 clamp(20px, 5vw, 32px);
	}

	.blog-post__head {
		margin-bottom: 32px;
	}

	.blog-post__back {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		margin-bottom: 22px;
		font-family: 'Press Start 2P', monospace;
		font-size: 0.62rem;
		letter-spacing: 0.24em;
		color: rgba(26, 26, 26, 0.5);
		text-decoration: none;
		transition: color 200ms ease, transform 300ms cubic-bezier(0.2, 0.8, 0.2, 1);
	}

	.blog-post__back:hover {
		color: #1a1a1a;
		transform: translateX(-3px);
	}

	.blog-post__eyebrow {
		margin: 0 0 14px;
		font-size: 0.78rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: rgba(26, 26, 26, 0.55);
	}

	.blog-post__updated {
		font-style: italic;
	}

	.blog-post__title {
		margin: 0 0 14px;
		font-size: clamp(1.7rem, 4.5vw, 2.6rem);
		line-height: 1.15;
		font-weight: 800;
		letter-spacing: -0.01em;
		color: #1a1a1a;
	}

	.blog-post__desc {
		margin: 0;
		font-size: 1.1rem;
		line-height: 1.5;
		color: rgba(26, 26, 26, 0.62);
	}

	.blog-post__divider {
		border: none;
		height: 1px;
		background: linear-gradient(to right, transparent, rgba(17, 17, 26, 0.18) 20%, rgba(17, 17, 26, 0.18) 80%, transparent);
		margin: 0 0 40px;
	}

	@media (max-width: 820px) {
		.blog-post {
			padding: clamp(80px, 12vh, 110px) 0 170px;
		}
		.blog-post__hero {
			margin-bottom: 36px;
			padding: 0 16px;
		}
		.blog-post__hero img {
			border-radius: 18px;
		}
		.blog-post__container {
			padding: 0 18px;
		}
		.blog-post__title {
			font-size: 1.55rem;
		}
		.blog-post__desc {
			font-size: 1rem;
		}
		.blog-post__divider {
			margin-bottom: 28px;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.blog-post__back {
			transition: none !important;
		}
	}
</style>
