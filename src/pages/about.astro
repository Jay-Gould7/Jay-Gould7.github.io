---
import BaseHead from '../components/BaseHead.astro';
import GlassTopBar from '../components/GlassTopBar';
import SocialsDock from '../components/SocialsDock.astro';
import AboutStack from '../components/AboutStack';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import '../styles/about.css';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body class="about-page">
		<GlassTopBar client:only="react" />
		<SocialsDock />

		<main class="about">
			<header class="about__head">
				<p class="about__eyebrow">ABOUT</p>
				<h1 class="about__title">HI, I'M JAY.</h1>
				<p class="about__subtitle">
					Designer &amp; tinkerer. I build small web experiments, collect moments
					through a lens, and write about both. Pick a door below.
				</p>
			</header>

			<AboutStack client:load />
		</main>
	</body>
</html>
