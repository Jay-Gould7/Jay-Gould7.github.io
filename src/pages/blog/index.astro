---
import { getImage } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import BlogList, { type BlogCard } from '../../components/BlogList';
import GlassTopBar from '../../components/GlassTopBar';
import SocialsDock from '../../components/SocialsDock.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import '../../styles/blog-list.css';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const HERO_WIDTH = 1000;
const HERO_HEIGHT = 400; // 5:2

const cards: BlogCard[] = await Promise.all(
	posts.map(async (post) => {
		let hero: BlogCard['hero'] = null;
		if (post.data.heroImage) {
			const img = await getImage({
				src: post.data.heroImage,
				width: HERO_WIDTH,
				height: HERO_HEIGHT,
				format: 'webp',
			});
			hero = { src: img.src, width: HERO_WIDTH, height: HERO_HEIGHT };
		}
		return {
			id: post.id,
			title: post.data.title,
			description: post.data.description,
			pubDate: post.data.pubDate.toISOString(),
			hero,
		};
	}),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Writings · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body class="blog-index-page">
		<GlassTopBar client:only="react" />
		<SocialsDock />

		<main class="blog-index">
			<header class="blog-index__head">
				<p class="blog-index__eyebrow">WRITINGS</p>
				<h1 class="blog-index__title">JAY'S BLOG</h1>
				<p class="blog-index__subtitle">
					Notes on design, web experiments, and the occasional deep dive.
				</p>
			</header>

			<BlogList client:load cards={cards} />
		</main>
	</body>
</html>
