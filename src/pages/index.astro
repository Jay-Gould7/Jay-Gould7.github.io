---
import BaseHead from '../components/BaseHead.astro';
import Hero3D from '../components/Hero3D';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="landing-page">
		<main class="landing-main" aria-label="3D homepage">
			<Hero3D client:only="react" />
		</main>
	</body>
</html>

<style is:global>
	body.landing-page {
		margin: 0;
		background: #08111f;
	}

	body.landing-page main {
		width: 100%;
		max-width: none;
		margin: 0;
		padding: 0;
	}
</style>

<style>
	.landing-main {
		width: 100vw;
		min-height: 100vh;
		height: 100vh;
		overflow: hidden;
	}

	@media (max-width: 720px) {
		.landing-main {
			height: 100svh;
			min-height: 100svh;
		}
	}
</style>
