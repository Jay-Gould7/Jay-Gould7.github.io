---
import BaseHead from '../components/BaseHead.astro';
import Hero3D from '../components/Hero3D';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="landing-page">
		<main class="landing-main" aria-label="3D homepage">
			<Hero3D client:only="react" />
		</main>
	</body>
</html>

<style is:global>
	body.landing-page {
		margin: 0;
		background: #cecdccff;
		overflow: hidden;
		overscroll-behavior: none;
	}

	body.landing-page main {
		width: 100%;
		max-width: none;
		margin: 0;
		padding: 0;
	}
</style>

<style>
	.landing-main {
		width: 100%;
		min-height: 100vh;
		height: 100vh;
		overflow: hidden;
		padding:
			0
			env(safe-area-inset-right, 0)
			0
			env(safe-area-inset-left, 0);
	}

	@supports (height: 100dvh) {
		.landing-main {
			height: 100dvh;
			min-height: 100dvh;
		}
	}

	@media (max-width: 720px) {
		.landing-main {
			height: calc(100lvh + env(safe-area-inset-top, 0) + env(safe-area-inset-bottom, 0) + 60px);
			min-height: calc(100lvh + env(safe-area-inset-top, 0) + env(safe-area-inset-bottom, 0) + 60px);
		}
	}
</style>
