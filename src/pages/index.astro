---
import BaseHead from '../components/BaseHead.astro';
import GlassTopBar from '../components/GlassTopBar';
import Hero3D from '../components/Hero3D';
import Profile from '../components/Profile.astro';
import SocialsDock from '../components/SocialsDock.astro';
import StartButton from '../components/StartButton.astro';
import StackedArticles from '../components/StackedArticles';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 3); // Show only the 3 most recent posts on the landing stack

const articleData = posts.map((post: any) => ({
    id: post.id,
    title: post.data.title,
    date: post.data.pubDate.toLocaleDateString('en-us', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
    }),
    excerpt: post.data.description,
    href: `/blog/${post.id}/`
}));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="landing-page">
		<main class="landing-main" aria-label="3D homepage">
			<Hero3D client:only="react" />

            <GlassTopBar client:only="react" />
            <SocialsDock />
            <StartButton />

            <div class="content-overlay">
                <div class="left-col">
                    <Profile />
                </div>
                
                <div class="right-col">
                    <section class="latest-articles">
                        <div class="articles-header">
                            <h2 class="section-title">LATEST WRITINGS</h2>
                        </div>
                        <StackedArticles client:load articles={articleData} />
                    </section>
                </div>
            </div>
		</main>
	</body>
</html>

<style is:global>
	body.landing-page {
		margin: 0;
		background: #DCDCDC; 
		overscroll-behavior: none;
        overflow: hidden; /* Strictly prevent all scrollbars */
	}

	/* Bottom fade pinned to the visible viewport so it stays aligned
	   with the page background even as iOS Safari's URL bar expands/collapses. */
	body.landing-page::after {
		content: '';
		position: fixed;
		left: 0;
		right: 0;
		bottom: 0;
		height: 18vh;
		background: linear-gradient(to top, #DCDCDC 0%, rgba(220, 220, 220, 0.78) 28%, rgba(220, 220, 220, 0) 100%);
		pointer-events: none;
		z-index: 1;
	}

	body.landing-page main {
		width: 100%;
		max-width: none;
		margin: 0;
		padding: 0;
	}

	/* Stacked articles sizing (desktop defaults preserved) */
	.stacked-articles-container {
		height: 500px;
	}

	.stacked-article-card {
		height: 380px;
		padding: 1.5rem;
	}

	@media (max-width: 820px) {
		/* Same vertical-card proportions as desktop, just slightly smaller */
		.stacked-articles-container {
			height: 380px;
		}
		.stacked-article-card {
			height: 340px;
			padding: 1.25rem;
		}
	}

	@media (max-width: 480px) {
		.stacked-articles-container {
			height: 340px;
		}
		.stacked-article-card {
			height: 300px;
			padding: 1rem;
		}
	}
</style>

<style>
	.landing-main {
		width: 100%;
		height: 100vh; /* Fixed exactly to viewport */
        position: relative;
        overflow: hidden; /* Prevent child content from stretching screen */
	}

    .content-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0; /* Anchor securely to the bottom bounds */
        z-index: 10;
        width: 100%;
        max-width: 100%;
        padding-top: clamp(140px, 18vh, 220px); /* Moved up together with wordmark */
        pointer-events: none;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        box-sizing: border-box;
    }

    .left-col {
        flex: 0 0 auto;
        padding-left: clamp(72px, 10vw, 132px);
        margin-top: clamp(20px, 3vh, 40px); /* Pushed down slightly per request */
    }

    .right-col {
        flex: 0 0 auto;
        display: flex;
        justify-content: flex-end;
        padding-right: clamp(40px, 8vw, 120px);
        width: 100%;
        max-width: 380px; 
        margin-top: clamp(30px, 10vh, 100px); /* Pushed down slightly per request */
    }

    .latest-articles {
        pointer-events: auto;
        width: 100%;
    }

    .articles-header {
        display: flex;
        justify-content: flex-end;
        margin-bottom: 2rem;
    }

    .section-title {
        font-family: 'Press Start 2P', monospace;
        font-size: 1rem;
        color: rgba(60,60,60,0.8); 
        letter-spacing: 0.05em;
        text-align: right;
        margin: 0;
    }

	@media (max-width: 820px) {
        /* Mobile homepage is fixed to a single viewport — no scrolling.
           dvh excludes the iOS/Android URL bar from the height calculation. */
        .landing-main {
            height: 100dvh;
        }

        .content-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            flex-direction: column;
            padding-left: 0;
            padding-top: clamp(170px, 20vh, 195px); /* keep profile BELOW the JAY'S BLOG wordmark */
            padding-bottom: 16px;
            gap: 1rem; /* spacing between profile and articles */
            overflow: hidden;
        }

        .left-col {
            padding-left: clamp(14px, 4vw, 24px);
            margin-top: 0;
            width: 100%;
            box-sizing: border-box;
        }

        .content-overlay .right-col {
            padding-right: clamp(14px, 4vw, 24px);
            padding-left: 0;
            margin-top: auto; /* push the article stack to the bottom of the viewport */
            justify-content: flex-end; /* pin the stack to the right, leave space on the left */
            max-width: 100%;
            width: 100%;
            align-self: stretch;
            box-sizing: border-box;
        }

        .content-overlay .right-col .latest-articles {
            width: clamp(220px, 60vw, 260px); /* narrow vertical card column */
            flex: 0 0 auto;
        }

        .articles-header {
            justify-content: flex-end;
            margin-bottom: 0.5rem;
        }

        .section-title {
            text-align: right;
            font-size: 0.75rem;
        }
	}

    @media (max-width: 480px) {
        .content-overlay {
            padding-top: clamp(155px, 19vh, 180px);
            gap: 0.85rem;
        }
        .latest-articles {
            width: clamp(200px, 58vw, 240px);
        }
    }
</style>

