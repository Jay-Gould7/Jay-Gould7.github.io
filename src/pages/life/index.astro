---
import BaseHead from '../../components/BaseHead.astro';
import GlassTopBar from '../../components/GlassTopBar';
import SocialsDock from '../../components/SocialsDock.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Life · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body class="placeholder-page">
		<GlassTopBar client:only="react" />
		<SocialsDock />

		<main class="placeholder">
			<a class="placeholder__back" href="/about/">← BACK</a>
			<p class="placeholder__eyebrow">LIFE</p>
			<h1 class="placeholder__title">Through my lens.</h1>
			<p class="placeholder__subtitle">
				A photo journal in the making. Places, light, and small moments worth
				keeping — with a few lines of context for each frame.
			</p>
		</main>

		<style is:global>
			body.placeholder-page {
				margin: 0;
				min-height: 100vh;
				background: #DCDCDC;
				color: #1a1a1a;
				font-family: 'Atkinson', system-ui, sans-serif;
			}
			.placeholder {
				max-width: 760px;
				margin: 0 auto;
				padding: clamp(80px, 11vh, 120px) clamp(24px, 6vw, 80px) 160px;
			}
			.placeholder__back {
				display: inline-block;
				margin-bottom: 40px;
				font-family: 'Press Start 2P', monospace;
				font-size: 0.62rem;
				letter-spacing: 0.22em;
				color: rgba(26, 26, 26, 0.6);
				text-decoration: none;
				transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1), color 0.2s;
			}
			.placeholder__back:hover {
				color: #1a1a1a;
				transform: translateX(-4px);
			}
			.placeholder__eyebrow {
				margin: 0 0 16px;
				font-family: 'Press Start 2P', monospace;
				font-size: 0.68rem;
				letter-spacing: 0.32em;
				color: rgba(26, 26, 26, 0.5);
			}
			.placeholder__title {
				margin: 0 0 18px;
				font-family: 'Press Start 2P', monospace;
				font-size: clamp(1.8rem, 5.2vw, 2.8rem);
				line-height: 1.1;
			}
			.placeholder__subtitle {
				max-width: 520px;
				color: rgba(26, 26, 26, 0.72);
				line-height: 1.55;
			}
			@media (max-width: 720px) {
				.placeholder { width: 100%; }
			}
			@media (max-width: 820px) {
				.placeholder { padding: clamp(58px, 8.5vh, 84px) 14px 140px; }
			}
		</style>
	</body>
</html>
