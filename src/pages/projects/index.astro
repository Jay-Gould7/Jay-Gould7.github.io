---
import BaseHead from '../../components/BaseHead.astro';
import GlassTopBar from '../../components/GlassTopBar';
import SocialsDock from '../../components/SocialsDock.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { PROJECTS } from '../../content/project/projects';
import { fetchRepo, type RepoMeta } from '../../lib/github';
import '../../styles/projects-list.css';

/* Resolve every curated entry to { curated, meta }.
   Runs once at build time; repos fetched in parallel so even a dozen
   entries finish in a second. A fetch failure leaves meta=null and
   the card gracefully falls back to the repo slug as its title. */
const enriched = await Promise.all(
	PROJECTS.map(async (p) => ({
		curated: p,
		meta: await fetchRepo(p.repo),
	})),
);

const highlighted = enriched.filter((e) => e.curated.highlight);
const regular = enriched.filter((e) => !e.curated.highlight);

function titleOf(full: string, meta: RepoMeta | null): string {
	return meta?.name ?? full.split('/')[1];
}

function hrefOf(full: string, meta: RepoMeta | null): string {
	return meta?.html_url ?? `https://github.com/${full}`;
}

function formatAgo(iso: string | undefined | null): string | null {
	if (!iso) return null;
	const diff = Date.now() - new Date(iso).getTime();
	const days = Math.round(diff / 86_400_000);
	if (days < 1) return 'today';
	if (days < 30) return `${days}d ago`;
	const months = Math.round(days / 30);
	if (months < 12) return `${months}mo ago`;
	return `${Math.round(months / 12)}y ago`;
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body class="projects-page">
		<GlassTopBar client:only="react" />
		<SocialsDock />

		<main class="projects-main">
			<header class="projects-head">
				<a class="projects-back" href="/about/">
					<span class="projects-back__arrow" aria-hidden="true">←</span>
					<span class="projects-back__label">BACK</span>
				</a>
				<p class="projects-eyebrow">PROJECTS</p>
			</header>

			{highlighted.length > 0 && (
				<section class="projects-section projects-section--hero">
					{highlighted.map(({ curated, meta }) => (
						<article class="project-card project-card--hero">
							<div class="project-card__row">
								<span class="project-card__eyebrow">
									{meta?.archived ? 'ARCHIVED' : 'FEATURED'}
								</span>
								{formatAgo(meta?.pushed_at) && (
									<span class="project-card__eyebrow">
										updated {formatAgo(meta?.pushed_at)}
									</span>
								)}
							</div>
							<h2 class="project-card__title">{titleOf(curated.repo, meta)}</h2>
							{meta?.description && (
								<p class="project-card__desc">{meta.description}</p>
							)}
							<div class="project-card__meta">
								{meta?.language && <span>{meta.language}</span>}
								{meta && <span>★ {meta.stargazers_count}</span>}
							</div>
							{meta?.topics?.length ? (
								<div class="project-card__tags">
									{meta.topics.slice(0, 6).map((t) => (
										<span class="tag">{t}</span>
									))}
								</div>
							) : null}
							<div class="project-card__links">
								<a
									class="link-chip"
									href={hrefOf(curated.repo, meta)}
									target="_blank"
									rel="noopener noreferrer"
								>
									CODE →
								</a>
								{meta?.homepage && (
									<a
										class="link-chip"
										href={meta.homepage}
										target="_blank"
										rel="noopener noreferrer"
									>
										DEMO →
									</a>
								)}
								{curated.writeup && (
									<a
										class="link-chip link-chip--ghost"
										href={`/blog/${curated.writeup}/`}
									>
										READ →
									</a>
								)}
							</div>
						</article>
					))}
				</section>
			)}

			{regular.length > 0 && (
				<section class="projects-section projects-section--grid">
					{regular.map(({ curated, meta }) => (
						<a
							class="project-card"
							href={hrefOf(curated.repo, meta)}
							target="_blank"
							rel="noopener noreferrer"
						>
							<div class="project-card__row">
								<span class="project-card__eyebrow">
									{meta?.archived ? 'ARCHIVED' : 'LIVE'}
								</span>
								<span class="project-card__arrow">↗</span>
							</div>
							<h3 class="project-card__title">{titleOf(curated.repo, meta)}</h3>
							{meta?.description && (
								<p class="project-card__desc">{meta.description}</p>
							)}
							<div class="project-card__meta">
								{meta?.language && <span>{meta.language}</span>}
								{meta && <span>★ {meta.stargazers_count}</span>}
								{formatAgo(meta?.pushed_at) && (
									<span>{formatAgo(meta?.pushed_at)}</span>
								)}
							</div>
						</a>
					))}
				</section>
			)}
		</main>
	</body>
</html>
